# ============================================================
# Python
# ============================================================
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
.eggs/

# ============================================================
# Environment & Secrets
# ============================================================
.env
.env.local
.env.production
*.tfvars
!*.tfvars.example
!infra/terraform/envs/*.tfvars
!infra/terraform/azure/envs/*.tfvars

# ============================================================
# Terraform
# ============================================================
**/.terraform/
**/tfplan
**/tfplan-*
**/terraform.tfstate
**/terraform.tfstate.backup
**/.terraform.lock.hcl

# ============================================================
# IDE / OS
# ============================================================
.DS_Store
.vscode/
*.code-workspace
.idea/
*.swp
*.swo
*~

# ============================================================
# Claude Code
# ============================================================
.claude/
.claude/worktrees/

# ============================================================
# Frontend (Node / Vite / Playwright)
# ============================================================
node_modules/
services/api/frontend/dist/
*.tsbuildinfo
services/api/frontend/test-results/
services/api/frontend/playwright-report/
services/api/frontend/blob-report/

# ============================================================
# Data (large files — tracked separately or via DVC)
