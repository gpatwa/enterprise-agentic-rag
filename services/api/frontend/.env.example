# Frontend env example. Copy to `.env.local` for per-developer overrides,
# or set in CI for production builds.

# Public site URL — used in <link rel="canonical">, OG/Twitter cards,
# JSON-LD, and the postbuild templater that rewrites dist/sitemap.xml +
# dist/robots.txt. MUST be set to the real production domain in CI for
# crawlers to discover the right URLs.
VITE_SITE_URL=https://compass.example.com

# Sentry — frontend error tracking. Leave unset to disable.
# Get a DSN from https://sentry.io → Project → Settings → Client Keys.
# VITE_SENTRY_DSN=https://abc123@o12345.ingest.sentry.io/67890
# VITE_SENTRY_ENVIRONMENT=alpha
# VITE_SENTRY_RELEASE=  # set in CI to git SHA

# Set to "1" to hide the in-app feedback widget (e.g. in production).
# Default: widget shown.
# VITE_FEEDBACK_DISABLED=0
